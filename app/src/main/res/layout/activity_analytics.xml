<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/primary" android:orientation="vertical"
            android:padding="16dp" android:paddingTop="48dp" android:paddingBottom="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊 Analytics Dashboard" android:textColor="@color/white"
                android:textSize="22sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Powered by Firebase Analytics + Gemini AI"
                android:textColor="#B3FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Overall Progress -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_margin="16dp"
            app:cardCornerRadius="12dp" app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📈 Overall Progress" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                <ProgressBar android:id="@+id/progress_analytics" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="14dp"
                    android:layout_marginTop="10dp" android:max="100"
                    android:progressDrawable="@drawable/progress_bar_style"/>

                <!-- 4 stat boxes -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="14dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="#E8EAF6" android:padding="10dp" android:layout_marginRight="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Chapters" android:textSize="11sp" android:textColor="#757575"/>
                        <TextView android:id="@+id/tv_total_chapters" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0/0"
                            android:textSize="16sp" android:textStyle="bold" android:textColor="@color/primary"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="#E8F5E9" android:padding="10dp" android:layout_marginRight="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Quizzes" android:textSize="11sp" android:textColor="#757575"/>
                        <TextView android:id="@+id/tv_total_quizzes" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="16sp" android:textStyle="bold" android:textColor="#2E7D32"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="#FFF9C4" android:padding="10dp" android:layout_marginRight="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Avg Score" android:textSize="11sp" android:textColor="#757575"/>
                        <TextView android:id="@+id/tv_overall_avg" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0%"
                            android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="#FFEBEE" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Gap Areas" android:textSize="11sp" android:textColor="#757575"/>
                        <TextView android:id="@+id/tv_gap_areas" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="16sp" android:textStyle="bold" android:textColor="#B71C1C"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Streak Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp" android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="#FBE9E7">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔥 Current Streak" android:textSize="13sp" android:textColor="#BF360C" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_current_streak" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="22sp"
                        android:textStyle="bold" android:textColor="#BF360C" android:text="0 days"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏆 Best Streak" android:textSize="13sp" android:textColor="#BF360C" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_best_streak" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="22sp"
                        android:textStyle="bold" android:textColor="#BF360C" android:text="0 days"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Weakest Chapter -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp" android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚠️ Focus Area (Weakest Chapter)" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                <TextView android:id="@+id/tv_weakest_chapter" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="15sp"
                    android:textColor="#B71C1C" android:textStyle="bold" android:layout_marginTop="6dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AI Study Tip -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp" android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="#E3F2FD">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Gemini AI Study Tip" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="#1565C0"/>
                <TextView android:id="@+id/tv_ai_tip" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="14sp"
                    android:textColor="#1565C0" android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp" android:text="🤖 Loading AI tip..."/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Subject Breakdown -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp" android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp" app:cardElevation="4dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📚 Subject Breakdown" android:textSize="15sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"/>
                <TextView android:id="@+id/tv_subject_breakdown" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="14sp"
                    android:textColor="@color/text_primary" android:layout_marginTop="10dp"
                    android:lineSpacingExtra="4dp" android:text="Loading..."/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
