<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/primary" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:padding="24dp" android:paddingTop="52dp" android:paddingBottom="32dp">

        <!-- Logo + App Name (always visible) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📚" android:textSize="64sp" android:layout_marginBottom="10dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Akshara-Deepa" android:textColor="#FFFFFF"
            android:textSize="28sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SSLC Class 10 Study Companion" android:textColor="#B3FFFFFF"
            android:textSize="13sp" android:layout_marginTop="4dp" android:layout_marginBottom="28dp"/>

        <!-- ══ SCREEN 0: METHOD CHOICE ══ -->
        <LinearLayout android:id="@+id/layout_method_choice"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#FFFFFF" android:padding="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Login / Register" android:textSize="20sp" android:textStyle="bold"
                android:textColor="#1A237E" android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Choose how you want to sign in:" android:textSize="14sp"
                android:textColor="#757575" android:layout_marginBottom="28dp"/>

            <!-- Phone OTP Button -->
            <Button android:id="@+id/btn_choose_phone"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="📱  Login with Mobile OTP"
                android:textSize="16sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary_bg" android:stateListAnimator="@null"
                android:layout_marginBottom="14dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E0E0E0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  OR  " android:textColor="#9E9E9E" android:textSize="13sp"/>
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E0E0E0"/>
            </LinearLayout>

            <!-- Email Button -->
            <Button android:id="@+id/btn_choose_email"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="✉️  Login with Email"
                android:textSize="15sp" android:textColor="#1A237E"
                android:backgroundTint="#E8EAF6" android:stateListAnimator="@null"
                android:layout_marginTop="14dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="100% Offline study • Free • SSLC Students"
                android:textSize="11sp" android:textColor="#BDBDBD"
                android:gravity="center" android:layout_marginTop="20dp"/>
        </LinearLayout>

        <!-- ══ SCREEN 1: EMAIL LOGIN / REGISTER ══ -->
        <LinearLayout android:id="@+id/layout_email"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:visibility="gone">

            <!-- Email Login Sub-screen -->
            <LinearLayout android:id="@+id/layout_email_login"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#FFFFFF" android:padding="24dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Welcome Back! 👋" android:textSize="20sp" android:textStyle="bold"
                    android:textColor="#1A237E" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sign in with your email" android:textSize="13sp"
                    android:textColor="#757575" android:layout_marginBottom="22dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Email" android:textSize="13sp" android:textColor="#424242"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_login_username" android:layout_width="match_parent"
                    android:layout_height="52dp" android:hint="Enter your email" android:textColor="#212121"
                    android:inputType="textEmailAddress" android:padding="12dp"
                    android:background="@drawable/input_bg" android:textSize="15sp"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Password" android:textSize="13sp" android:textColor="#424242"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_login_password" android:layout_width="match_parent"
                    android:layout_height="52dp" android:hint="Enter your password" android:textColor="#212121"
                    android:inputType="textPassword" android:padding="12dp"
                    android:background="@drawable/input_bg" android:textSize="15sp"
                    android:layout_marginBottom="22dp"/>

                <Button android:id="@+id/btn_login" android:layout_width="match_parent"
                    android:layout_height="52dp" android:text="Login →" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary_bg" android:stateListAnimator="@null"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="New student? " android:textSize="14sp" android:textColor="#616161"/>
                    <TextView android:id="@+id/tv_go_register" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Create Account"
                        android:textSize="14sp" android:textColor="#FF6F00" android:textStyle="bold"/>
                </LinearLayout>

                <TextView android:id="@+id/tv_back_from_email"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="← Back to login options" android:textSize="13sp"
                    android:textColor="#9E9E9E" android:gravity="center" android:padding="12dp"/>
            </LinearLayout>

            <!-- Email Register Sub-screen -->
            <LinearLayout android:id="@+id/layout_email_register"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#FFFFFF"
                android:padding="24dp" android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Create Account 🎓" android:textSize="20sp" android:textStyle="bold"
                    android:textColor="#1A237E" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Register to start your mission" android:textSize="13sp"
                    android:textColor="#757575" android:layout_marginBottom="20dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Full Name" android:textSize="13sp" android:textColor="#424242"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_reg_name" android:layout_width="match_parent"
                    android:layout_height="52dp" android:hint="e.g. Deepa K S" android:textColor="#212121"
                    android:inputType="textPersonName" android:padding="12dp"
                    android:background="@drawable/input_bg" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Class / School" android:textSize="13sp" android:textColor="#424242"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_reg_class" android:layout_width="match_parent"
                    android:layout_height="52dp" android:hint="e.g. Class 10, HKBK School" android:textColor="#212121"
                    android:inputType="text" android:padding="12dp"
                    android:background="@drawable/input_bg" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Email" android:textSize="13sp" android:textColor="#424242"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_reg_username" android:layout_width="match_parent"
                    android:layout_height="52dp" android:hint="your@email.com" android:textColor="#212121"
                    android:inputType="textEmailAddress" android:padding="12dp"
                    android:background="@drawable/input_bg" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Password" android:textSize="13sp" android:textColor="#424242"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/et_reg_password" android:layout_width="match_parent"
                    android:layout_height="52dp" android:hint="Min 6 characters" android:textColor="#212121"
                    android:inputType="textPassword" android:padding="12dp"
                    android:background="@drawable/input_bg" android:layout_marginBottom="20dp"/>

                <Button android:id="@+id/btn_register" android:layout_width="match_parent"
                    android:layout_height="52dp" android:text="Create Account 🎉"
                    android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF"
                    android:background="@drawable/btn_primary_bg" android:stateListAnimator="@null"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Already have account? " android:textSize="14sp" android:textColor="#616161"/>
                    <TextView android:id="@+id/tv_go_login" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Login"
                        android:textSize="14sp" android:textColor="#FF6F00" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SCREEN 2: ENTER PHONE NUMBER ══ -->
        <LinearLayout android:id="@+id/layout_phone_enter"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#FFFFFF"
            android:padding="24dp" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📱 Mobile OTP Login" android:textSize="20sp" android:textStyle="bold"
                android:textColor="#1A237E" android:layout_marginBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Enter your mobile number to receive OTP"
                android:textSize="13sp" android:textColor="#757575" android:layout_marginBottom="24dp"/>

            <!-- Country code + phone in one row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="22dp">
                <TextView android:layout_width="wrap_content" android:layout_height="52dp"
                    android:text="🇮🇳 +91" android:textSize="15sp" android:textColor="#212121"
                    android:textStyle="bold" android:gravity="center"
                    android:background="@drawable/input_bg" android:padding="10dp"
                    android:layout_marginRight="8dp"/>
                <EditText android:id="@+id/et_phone" android:layout_width="0dp"
                    android:layout_height="52dp" android:layout_weight="1"
                    android:hint="10-digit mobile number"
                    android:textColor="#212121" android:inputType="phone"
                    android:padding="12dp" android:background="@drawable/input_bg"
                    android:textSize="16sp" android:maxLength="10"/>
            </LinearLayout>

            <Button android:id="@+id/btn_send_otp"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="Send OTP →" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:background="@drawable/btn_primary_bg"
                android:stateListAnimator="@null"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="📩 A 6-digit OTP will be sent via SMS to your number"
                android:textSize="12sp" android:textColor="#9E9E9E"
                android:gravity="center" android:layout_marginTop="12dp"/>

            <TextView android:id="@+id/tv_back_from_phone"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="← Back to login options" android:textSize="13sp"
                android:textColor="#9E9E9E" android:gravity="center" android:padding="14dp"/>
        </LinearLayout>

        <!-- ══ SCREEN 3: ENTER OTP ══ -->
        <LinearLayout android:id="@+id/layout_otp_verify"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#FFFFFF"
            android:padding="24dp" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅ OTP Sent!" android:textSize="20sp" android:textStyle="bold"
                android:textColor="#1A237E" android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/tv_otp_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Enter the 6-digit OTP sent to your mobile"
                android:textSize="13sp" android:textColor="#757575"
                android:lineSpacingExtra="4dp" android:layout_marginBottom="24dp"/>

            <!-- OTP Input boxes styled -->
            <EditText android:id="@+id/et_otp"
                android:layout_width="match_parent" android:layout_height="64dp"
                android:hint="  —  —  —  —  —  —"
                android:textColor="#1A237E" android:inputType="number"
                android:maxLength="6" android:textSize="28sp" android:textStyle="bold"
                android:gravity="center" android:letterSpacing="0.3"
                android:background="@drawable/input_bg" android:layout_marginBottom="8dp"/>

            <TextView android:id="@+id/tv_otp_timer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Resend OTP in 60s" android:textSize="13sp"
                android:textColor="#9E9E9E" android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <Button android:id="@+id/btn_verify_otp"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="Verify OTP ✓" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:background="@drawable/btn_primary_bg"
                android:stateListAnimator="@null" android:layout_marginBottom="12dp"/>

            <Button android:id="@+id/btn_resend_otp"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Resend OTP" android:textSize="14sp"
                android:textColor="#1A237E" android:backgroundTint="#E8EAF6"
                android:enabled="false" android:stateListAnimator="@null"
                android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/tv_resend"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:visibility="gone"/>

            <TextView android:id="@+id/tv_back_from_otp"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="← Change phone number" android:textSize="13sp"
                android:textColor="#9E9E9E" android:gravity="center" android:padding="12dp"/>
        </LinearLayout>

        <!-- Loading -->
        <ProgressBar android:id="@+id/progress_login"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:layout_marginTop="16dp"
            android:visibility="gone" android:indeterminateTint="#FFFFFF"/>

    </LinearLayout>
</ScrollView>
