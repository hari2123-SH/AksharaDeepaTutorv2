<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:id="@+id/tv_splash_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚"
        android:textSize="72sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Akshara-Deepa"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold"
        android:alpha="0"
        android:letterSpacing="0.05"
        android:gravity="center"/>

    <TextView
        android:id="@+id/tv_splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your SSLC Study Companion"
        android:textColor="#B3FFFFFF"
        android:textSize="16sp"
        android:alpha="0"
        android:layout_marginTop="12dp"
        android:gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Class 10 • Science • Maths • Social Studies"
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

</LinearLayout>
